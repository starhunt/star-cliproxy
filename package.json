{
  "name": "star-cliproxy",
  "version": "1.3.0",
  "private": true,
  "description": "AI CLI Subscription Proxy Service - OpenAI-compatible API proxy for Claude, Codex, and Gemini CLIs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:dashboard\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/server && npm run build --workspace=packages/dashboard",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/**/*.{ts,tsx}",
    "typecheck": "tsc --build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "concurrently": "^9.1.2",
    "pino-pretty": "^13.0.0"
  }
}
