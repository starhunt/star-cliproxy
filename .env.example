# Generate a strong admin token first:
#   openssl rand -hex 32
# or:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-admin-token
# Generate a proxy API key with the required sk-proxy- prefix:
#   echo "sk-proxy-$(openssl rand -hex 24)"
# or:
#   node -e "console.log('sk-proxy-' + require('crypto').randomBytes(24).toString('hex'))"
PROXY_API_KEY=sk-proxy-change-me-key
